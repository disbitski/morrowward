# Optional. The full simulator works without an API key.
OPENAI_API_KEY=

# Optional canonical origin used for Open Graph metadata in non-Vercel hosts.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Required for scheduled GET or manual POST /api/v1/briefs/generate.
CRON_SECRET=

# Optional alternative bearer token for a manually triggered brief generation.
ADMIN_API_TOKEN=

# Optional durable daily-brief cache. Set both values in one complete pair.
# If both pairs are complete, the KV_REST_API pair takes precedence.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Alternative complete pair used by a direct Upstash Redis integration.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional future live-quote provider. The MVP uses labeled educational samples.
TWELVE_DATA_API_KEY=
