# Optional. The full simulator works without an API key.
OPENAI_API_KEY=

# Optional canonical origin used for Open Graph metadata in non-Vercel hosts.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Required for scheduled GET or manual POST /api/v1/briefs/generate.
CRON_SECRET=

# Optional alternative bearer token for a manually triggered brief generation.
ADMIN_API_TOKEN=

# Optional durable daily-brief cache. Set both values in one complete pair.
# If both pairs are complete, the KV_REST_API pair takes precedence.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Alternative complete pair used by a direct Upstash Redis integration.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional server-only market-data provider. The default remains labeled
# synthetic sample data. All three values are required before any provider call;
# set the rights flag only when your account permits external/public display.
TWELVE_DATA_API_KEY=
TWELVE_DATA_DISPLAY_MODE=
MARKET_DATA_PUBLIC_DISPLAY_ALLOWED=false

# Optional local-only media tooling. Never expose this in browser code or add it
# to Vercel; scripts/grok writes generated candidates only to .media-review/.
XAI_API_KEY=
