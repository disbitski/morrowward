# Optional. The full simulator works without an API key.
OPENAI_API_KEY=

# Optional canonical origin used for Open Graph metadata in non-Vercel hosts.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Required for scheduled GET or manual POST generation routes:
# /api/v1/briefs/generate and /api/v1/quotes/generate.
CRON_SECRET=

# Optional alternative bearer token for either manually triggered generation route.
ADMIN_API_TOKEN=

# Optional durable daily-content cache for generated briefs and the shared
# daily quote snapshot. Set both values in one complete pair.
# If both pairs are complete, the KV_REST_API pair takes precedence.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Alternative complete pair used by a direct Upstash Redis integration.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional local-only media tooling. Never expose this in browser code or add it
# to Vercel; scripts/grok writes generated candidates only to .media-review/.
XAI_API_KEY=
